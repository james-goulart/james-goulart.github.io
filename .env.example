OPENAI_API_KEY=sk-your-key-here
# Default: gpt-4o-mini (strong quality per dollar for Q&A). Optional: gpt-4o for higher quality.
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional — only if your OpenAI dashboard shows a required Organization or Project for this key:
# OPENAI_ORG_ID=org-...
# OPENAI_PROJECT_ID=proj_...
# If you see auth errors and you did NOT mean to use an org/project, remove these from Windows
# Environment Variables (System Properties) so they are not set globally.
